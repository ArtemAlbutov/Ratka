# Самый главный файл настроек
root = true

# Настройки для ВСЕХ файлов
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# !!! САМОЕ ВАЖНОЕ ДЛЯ ТЕБЯ !!!
# Эта команда отключает автоматическое добавление пустой строки в конце
insert_final_newline = false
